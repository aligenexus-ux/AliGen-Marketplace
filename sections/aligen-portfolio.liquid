                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "type": "text",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            "id": "title",
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  "label": "العنوان",
