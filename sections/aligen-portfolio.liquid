{% liquid
assign section_title = section.settings.title
assign section_subtitle = section.settings.subtitle
%}

<section id="aligen-portfolio-{{ section.id }}" class="aligen-portfolio">

  <div class="page-width">
  
      <div class="portfolio-header">
      
            <span class="portfolio-badge">
                    {{ section.settings.badge }}
                          </span>
                          
                                <h2 class="portfolio-title">
                                        {{ section_title }}
                                              </h2>
                                              
                                                    <p class="portfolio-subtitle">
                                                            {{ section_subtitle }}
                                                                  </p>
                                                                  
                                                                      </div>
                                                                      
                                                                          <div class="portfolio-grid">
                                                                          
                                                                                {% for block in section.blocks %}
                                                                                
                                                                                      <div class="portfolio-card">
                                                                                      
                                                                                              {% if block.settings.image != blank %}
                                                                                                      <div class="portfolio-image">
                                                                                                                <img
                                                                                                                            src="{{ block.settings.image | image_url: width: 1200 }}"
                                                                                                                                        alt="{{ block.settings.title }}"
                                                                                                                                                    loading="lazy"
                                                                                                                                                                width="1200"
                                                                                                                                                                            height="800">
                                                                                                                                                                                    </div>
                                                                                                                                                                                            {% endif %}
                                                                                                                                                                                            
                                                                                                                                                                                                    <div class="portfolio-content">
                                                                                                                                                                                                    
                                                                                                                                                                                                              <span class="portfolio-category">
                                                                                                                                                                                                                          {{ block.settings.category }}
                                                                                                                                                                                                                                    </span>
                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                              <h3>
                                                                                                                                                                                                                                                          {{ block.settings.title }}
                                                                                                                                                                                                                                                                    </h3>
                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                              <p>
                                                                                                                                                                                                                                                                                          {{ block.settings.description }}
                                                                                                                                                                                                                                                                                                    </p>
                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                              <div class="portfolio-buttons">
                                                                                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                                                                                          {% if block.settings.demo_url != blank %}
                                                                                                                                                                                                                                                                                                                                      <a
                                                                                                                                                                                                                                                                                                                                                    href="{{ block.settings.demo_url }}"
                                                                                                                                                                                                                                                                                                                                                                  class="portfolio-btn portfolio-btn-primary"
                                                                                                                                                                                                                                                                                                                                                                                target="_blank">
                                                                                                                                                                                                                                                                                                                                                                                              👁 معاينة الموقع
                                                                                                                                                                                                                                                                                                                                                                                                          </a>
                                                                                                                                                                                                                                                                                                                                                                                                                      {% endif %}
                                                                                                                                                                                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                                                                                                                                                                                                  {% if block.settings.order_url != blank %}
                                                                                                                                                                                                                                                                                                                                                                                                                                              <a
                                                                                                                                                                                                                                                                                                                                                                                                                                                            href="{{ block.settings.order_url }}"
                                                                                                                                                                                                                                                                                                                                                                                                                                                                          class="portfolio-btn portfolio-btn-secondary">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        🚀 اطلب هذا المشروع
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </a>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                {% endif %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              {% endfor %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    </section>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {% schema %}
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      "name": "AliGen Portfolio",
